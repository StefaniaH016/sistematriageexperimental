# ============================================================
# PLANTILLA DE CONFIGURACIÓN (.env.example)
# Copia este archivo como '.env' en la raíz y completa los valores.
# El archivo '.env' real NUNCA debe subirse a Git.
# ============================================================

# Nombre del proyecto (prefijo para recursos Docker)
COMPOSE_PROJECT_NAME=triage-sistema

# Puerto expuesto para el Frontend (por defecto 80)
FRONTEND_PORT=80

# ─────────────────────────────────────────────────────────────
# CONFIGURACIÓN DE BASE DE DATOS (MariaDB)
# ─────────────────────────────────────────────────────────────
DB_NAME=${{MYSQL_DATABASE:-railway}}
DB_USER=${{MYSQL_USER:-root}}
DB_PASSWORD=${{MYSQL_PASSWORD:-root}}
# URL JDBC para el backend. En Docker Compose el servicio interno usa el puerto 3306.
# Si conectas con HeidiSQL desde Windows, usa localhost:3307.
DB_URL=${{MYSQL_URL:mysql://root:KnPavOUMPokkAuTXngFooeXXwvJphyrR@mysql.railway.internal:3306/railway}}
# Puerto de MariaDB expuesto en la máquina local (desarrollo)
DB_PORT=${MYSQL_PORT:3306}

# ─────────────────────────────────────────────────────────────
# SEGURIDAD Y JWT
# ─────────────────────────────────────────────────────────────
# Secreto JWT para firmar tokens. Debe ser seguro y largo (mínimo 64 caracteres/bytes).
# Generación recomendada en Git Bash / terminal Linux: openssl rand -base64 64
JWT_SECRET=${JWT_SECRET:PyYOZKk58IsJawsYXD1vuY7rpC863z6UaV2UivEDuzQ=}

# Orígenes permitidos para CORS cuando el frontend y backend no están en el mismo dominio.
# Por ejemplo: https://mi-app.vercel.app, https://mi-backend.up.railway.app
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,https://localhost:*,http://127.0.0.1:*,https://127.0.0.1:*,https://*.vercel.app,https://*.railway.app

# ─────────────────────────────────────────────────────────────
# INTELIGENCIA ARTIFICIAL (GEMINI API)
# ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=${GEMINI_API_KEY:AIzaSyAw7Q2MykvJpCUlllfNX590b8qthBbqVo8}
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1/models/gemini-3.5-flash:generateContent
GEMINI_API_MODEL=gemini-3.5-flash

# ─────────────────────────────────────────────────────────────
# CONFIGURACIÓN DE SPRING BOOT
# ─────────────────────────────────────────────────────────────
# DB_TYPE: mariadb o mysql
DB_TYPE=mariadb
# DB_DRIVER: org.mariadb.jdbc.Driver o com.mysql.cj.jdbc.Driver
DB_DRIVER=org.mariadb.jdbc.Driver
# DDL_AUTO: update, create, create-drop, validate, none
DDL_AUTO=update
# LOG_LEVEL: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────
# LÍMITE DE ASIGNACIÓN DE SOLICITUDES
# ─────────────────────────────────────────────────────────────
SOLICITUDES_LIMITE_ASIGNACION=5
